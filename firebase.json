{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase/**",
      ".git/**",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "package.json",
      "package-lock.json",
      "firestore.rules"
    ],
    "rewrites": [
      { "source": "/api/**", "run": { "serviceId": "voyage", "region": "asia-east1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
