rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    // 每個使用者只能寫自己的 profile
    match /users/{userId} {
      allow read:  if signedIn();
      allow write: if signedIn() && uid() == userId;
    }

    // 邀請碼：登入者可讀（只揭露 gid 與名稱），建立群組時寫入
    match /codes/{code} {
      allow read:  if signedIn();
      allow write: if signedIn();
    }

    // 群組本體：只有成員能讀寫；非成員只能「把自己加進成員」來加入
    match /groups/{gid} {
      allow read:   if signedIn() && uid() in resource.data.members;
      allow create: if signedIn() && uid() in request.resource.data.members;
      allow update: if signedIn() && (
                       uid() in resource.data.members            // 既有成員可更新
                       || (                                       // 或：新成員加入自己
                            uid() in request.resource.data.members
                            && resource.data.members.size() + 1 == request.resource.data.members.size()
                          )
                    );
      allow delete: if signedIn() && resource.data.ownerId == uid();

      // 聊天訊息：獨立文件，只有成員能讀、只能以自己身分發、不可竄改
      match /messages/{mid} {
        function group() { return get(/databases/$(database)/documents/groups/$(gid)).data; }
        allow read:   if signedIn() && uid() in group().members;
        allow create: if signedIn()
                      && uid() == request.resource.data.uid
                      && uid() in group().members;
        allow update, delete: if false;
      }
    }
  }
}
